---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrackListing from '../../components/TrackListing.astro';
import DifficultyScale from '../../components/DifficultyScale.astro';
import OwnedToggle from '../../components/OwnedToggle.tsx';
import { getBooks, getSongsByBookOrdered, getPlaylistsForBook, getAmazonAffiliateUrl, hasAmazonAffiliate } from '../../lib/data';
import type { Book, Song } from '../../lib/types';

export function getStaticPaths() {
  const books = getBooks();
  return books.map((book) => ({
    params: { id: book.id },
    props: { book },
  }));
}

interface Props {
  book: Book;
}

const { book } = Astro.props;
const songs: Song[] = getSongsByBookOrdered(book.id);
const playlists = getPlaylistsForBook(book.id);
const bookHasVideos = songs.some((s) => s.youtubeLinks.length > 0);
const firstSong = songs[0];

// Show incomplete warning if we have songs but the listing looks suspiciously short
// (pages-per-song ratio > 5 suggests missing entries from publisher extraction)
const trackListingIncomplete = songs.length > 0 && book.pageCount !== null && book.pageCount / songs.length > 5;

// Compute publisher page URL
function getPublisherUrl(book: Book): string | null {
  if (book.publisher === 'Faber Piano Adventures') {
    const isFaberAdult = book.series === 'Faber Adult Piano Adventures';
    const slug = isFaberAdult
      ? book.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '')
      : book.id;
    return `https://pianoadventures.com/product/${slug}/`;
  }
  if (book.publisher === 'Alfred Music' && book.isbn) {
    return `https://www.alfred.com/search/?query=${book.isbn}`;
  }
  return null;
}
const publisherUrl = getPublisherUrl(book);
---

<BaseLayout title={book.title} description={book.description}>
  <div class="mb-6">
    <a href="/books" class="inline-flex items-center gap-1 text-sm text-piano-600 hover:text-piano-700 dark:text-piano-400 dark:hover:text-piano-300">
      ← Back to Books
    </a>
  </div>

  <div class="flex flex-col gap-6 sm:flex-row">
    {/* Book Cover */}
    <div class="shrink-0 sm:w-48">
      <div class="aspect-[3/4] overflow-hidden rounded-lg bg-gray-100 shadow-md dark:bg-gray-800">
        {book.coverImage ? (
          <img
            src={book.coverImage}
            alt={`Cover of ${book.title}`}
            class="h-full w-full object-cover"
          />
        ) : (
          <div class="flex h-full items-center justify-center p-4 text-center">
            <div>
              <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V4.5l-10.5 3v6.75m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 4.5 15V4.5" /></svg>
              <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">{book.title}</p>
            </div>
          </div>
        )}
      </div>
    </div>

    {/* Book Info */}
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-100">
        {book.title}
      </h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
        {book.series} &middot; {book.seriesLevel}
      </p>

      {firstSong && (
        <div class="mt-3">
          <DifficultyScale label={firstSong.difficulty.label} faberLevel={firstSong.difficulty.faberLevel} alfredLevel={firstSong.difficulty.alfredLevel} size="md" orientation="horizontal" />
        </div>
      )}

      <p class="mt-3 text-sm text-gray-700 dark:text-gray-300">
        {book.description}
      </p>

      <div class="mt-4 flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
        <div><strong>Publisher:</strong> {book.publisher}</div>
        {book.isbn && <div><strong>ISBN:</strong> {book.isbn}</div>}
        {book.pageCount && <div><strong>Pages:</strong> {book.pageCount}</div>}
      </div>

      <div class="mt-4 flex items-center gap-3">
        <OwnedToggle client:load bookId={book.id} />
        {publisherUrl && (
          <a
            href={publisherUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-600 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-gray-800"
          >
            {book.publisher} ↗
          </a>
        )}
        {book.amazonUrl && (
          <a
            href={getAmazonAffiliateUrl(book.amazonUrl)}
            target="_blank"
            rel="sponsored noopener noreferrer"
            class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm text-gray-600 hover:bg-gray-50 dark:border-gray-600 dark:text-gray-400 dark:hover:bg-gray-800"
          >
            Amazon ↗
          </a>
        )}
      </div>
      {book.amazonUrl && hasAmazonAffiliate && (
        <p class="mt-2 text-xs text-gray-400 dark:text-gray-500">As an Amazon Associate I earn from qualifying purchases.</p>
      )}

      {/* YouTube Playlists */}
      {playlists.length > 0 && (
        <div class="mt-4">
          <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">YouTube Playlists</h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {playlists.map((pl) => (
              <a
                href={pl.playlistUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-lg bg-red-50 px-3 py-1.5 text-sm text-red-700 hover:bg-red-100 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50"
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
                {pl.channelName} ({pl.trackCount} videos)
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  {/* Song listing */}
  <div class="mt-8">
    {trackListingIncomplete && (
      <div class="mb-3 rounded-lg border border-amber-300 bg-amber-50 p-3 text-sm text-amber-800 dark:border-amber-700 dark:bg-amber-900/20 dark:text-amber-300">
        ⚠ Track listing may be incomplete — not all songs from this book are available yet.
      </div>
    )}
    {songs.length > 0 ? (
      <TrackListing songs={songs} bookHasVideos={bookHasVideos} bookId={book.id} />
    ) : (
      <p class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">
        No songs listed yet. Edit songs.json to add them.
      </p>
    )}
  </div>
</BaseLayout>
