---
import type { Song } from '../lib/types';
import { getBookById } from '../lib/data';
import DifficultyBadge from './DifficultyBadge.astro';

interface Props {
  song: Song;
  showBook?: boolean;
  showOwnership?: boolean;
  bookHasVideos?: boolean;
}

const { song, showBook = true, showOwnership = true, bookHasVideos = false } = Astro.props;
const book = getBookById(song.bookId);
---

<a
  href={`/songs/${song.id}`}
  {...(showOwnership ? { 'data-owned-card': true, 'data-book-id': song.bookId } : {})}
  class={`group block rounded-lg border p-4 transition-all hover:shadow-md ${
    song.youtubeLinks.length > 0
      ? 'border-gray-200 bg-white hover:border-piano-300 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-piano-700'
      : bookHasVideos
        ? 'border-gray-200 bg-gray-50/50 hover:border-gray-300 dark:border-gray-800 dark:bg-gray-900/60 dark:hover:border-gray-700'
        : 'border-gray-200 bg-white hover:border-piano-300 dark:border-gray-800 dark:bg-gray-900 dark:hover:border-piano-700'
  }`}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <h3 class="truncate font-semibold text-gray-900 group-hover:text-piano-700 dark:text-gray-100 dark:group-hover:text-piano-400">
        {song.title}
      </h3>
      <p class="mt-0.5 text-sm text-gray-600 dark:text-gray-400">
        {song.composer}
      </p>
      {showBook && book && (
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">
          {book.title}
          {song.pageNumber && <span> &middot; p.{song.pageNumber}</span>}
        </p>
      )}
      {!showBook && song.pageNumber && (
        <p class="mt-1 text-xs text-gray-500 dark:text-gray-500">
          p.{song.pageNumber}
        </p>
      )}
    </div>
    <div class="flex shrink-0 flex-col items-end gap-1.5">
      <DifficultyBadge label={song.difficulty.label} />
      {showOwnership && (
        <span data-owned-indicator data-book-id={song.bookId} class="hidden rounded px-2 py-0.5 text-xs font-medium">
          ✓ In Library
        </span>
      )}
      {song.genre && (
        <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600 dark:bg-gray-800 dark:text-gray-400">
          {song.genre}
        </span>
      )}
    </div>
  </div>
  <div class={`mt-2 flex items-center gap-1 text-xs ${song.youtubeLinks.length > 0 ? 'text-red-600 dark:text-red-400' : 'text-gray-400 dark:text-gray-600'}`}>
    {song.youtubeLinks.length > 0 ? (
      <>
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        <span>{song.youtubeLinks.length} video{song.youtubeLinks.length > 1 ? 's' : ''}</span>
      </>
    ) : (
      <>
        <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25l-3 3m0 0l-3-3m3 3V3m-6.75 9A6.75 6.75 0 0012 18.75 6.75 6.75 0 0018.75 12M5.25 12a6.75 6.75 0 010-1.5"/></svg>
        <span>No video yet</span>
      </>
    )}
  </div>
</a>
