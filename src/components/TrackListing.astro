---
import type { Song } from '../lib/types';
import { hasRelatedSongs } from '../lib/data';

interface Props {
  songs: Song[];
  currentSongId?: string;
  bookHasVideos: boolean;
  bookId: string;
  showAutoplay?: boolean;
  maxHeight?: string;
}

const {
  songs,
  currentSongId,
  bookHasVideos,
  bookId,
  showAutoplay = false,
  maxHeight,
} = Astro.props;
---

<div class="rounded-lg border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900">
  <div class="flex items-center justify-between gap-2">
    <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100">
      Track Listing ({songs.length})
    </h2>
    <div class="flex items-center gap-3">
      {showAutoplay && bookHasVideos && (
        <button
          id="autoplay-toggle"
          type="button"
          class="inline-flex items-center gap-1 rounded-md border border-gray-300 px-2 py-1 text-xs text-gray-500 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-800"
          title="When enabled, clicking a track will autoplay its video"
        >
          <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          <span>Autoplay</span>
        </button>
      )}
      {currentSongId && (
        <a href={`/books/${bookId}`} class="text-xs text-piano-600 hover:text-piano-700 dark:text-piano-400 dark:hover:text-piano-300">
          View Book
        </a>
      )}
    </div>
  </div>
  <ul id="track-listing" class="mt-3 space-y-0.5 overflow-y-auto pr-1" style={maxHeight ? `max-height: ${maxHeight}` : undefined}>
    {songs.map((bookSong, index) => {
      const isCurrent = bookSong.id === currentSongId;
      const hasVideo = bookSong.youtubeLinks.length > 0;
      return (
        <li>
          <a
            href={`/songs/${bookSong.id}`}
            aria-current={isCurrent ? 'page' : undefined}
            data-track-link
            class:list={[
              'flex items-center justify-between gap-2 rounded-md px-2 py-2 text-sm',
              isCurrent
                ? 'bg-piano-100 font-medium text-piano-800 dark:bg-piano-900/40 dark:text-piano-300'
                : 'text-gray-700 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-800',
            ]}
          >
            <span class="flex min-w-0 items-center gap-1.5">
              <span class="w-6 shrink-0 text-right text-xs text-gray-400 dark:text-gray-500">{index + 1}.</span>
              <button
                type="button"
                class="p-1 text-sm text-gray-300 hover:text-pink-500 dark:text-gray-600 dark:hover:text-pink-400"
                data-fav-toggle
                data-song-id={bookSong.id}
                title="Toggle favorite"
                onclick="event.preventDefault();"
              >♡</button>
              <span class="truncate">{bookSong.title}</span>
              {bookSong.composer && !isCurrent && (
                <span class="hidden truncate text-xs text-gray-400 dark:text-gray-500 sm:inline">
                  — {bookSong.composer}
                </span>
              )}
            </span>
            <span class="flex shrink-0 items-center gap-2">
              {hasRelatedSongs(bookSong.id) && (
                <svg class="h-3.5 w-3.5 text-piano-500 dark:text-piano-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" title="Also in other books"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              )}
              {hasVideo && (
                <svg class="h-3.5 w-3.5 text-red-500 dark:text-red-400" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              )}
              {bookSong.pageNumber !== null && (
                <span class="text-xs text-gray-400 dark:text-gray-500">p.{bookSong.pageNumber}</span>
              )}
            </span>
          </a>
        </li>
      );
    })}
  </ul>
</div>
