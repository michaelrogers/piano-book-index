---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Browse and search piano songs across Faber and Alfred method book series' } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/+$/, '') || '/';

import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';
import MobileDrawer from '../components/MobileDrawer.tsx';
import PWABottomNav from '../components/PWABottomNav.tsx';
import PWAInstallPrompt from '../components/PWAInstallPrompt.tsx';
---

<!doctype html>
<html lang="en" class="dark:bg-gray-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#7e22ce" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Piano Index" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <title>{title} | Piano Book Index</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        var dark = t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur safe-top dark:border-gray-800 dark:bg-gray-950/80">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-piano-700 dark:text-piano-400">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="3" width="22" height="18" rx="2" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
            <!-- White keys: C D E F G -->
            <rect x="2" y="5" width="3.8" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="6" y="5" width="3.8" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="10" y="5" width="3.8" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="14" y="5" width="3.8" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="18" y="5" width="3.8" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <!-- Black keys: C# D# (gap between E-F) F# -->
            <rect x="5" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
            <rect x="9" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
            <rect x="17" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
          </svg>
          <span>Piano Book Index</span>
        </a>
        <div class="flex items-center gap-1">
          <ul class="hidden items-center gap-1 text-sm sm:flex">
            <li>
              <a
                href="/search"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/search' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Search
              </a>
            </li>
            <li>
              <a
                href="/books"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath.startsWith('/books') && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Books
              </a>
            </li>
            <li>
              <a
                href="/favorites"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/favorites' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Favorites
              </a>
            </li>
            <li>
              <a
                href="/difficulty"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/difficulty' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Difficulty
              </a>
            </li>
          </ul>
          <div class="hidden sm:block">
            <ThemeToggle client:load />
          </div>
          <!-- Mobile hamburger (static HTML, no JS dependency) -->
          <button
            id="mobile-menu-btn"
            class="rounded-md p-2 text-gray-500 transition-colors hover:bg-gray-100 sm:hidden dark:text-gray-400 dark:hover:bg-gray-800"
            aria-label="Open menu"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <MobileDrawer client:load currentPath={currentPath} />

    <main class="mx-auto max-w-5xl px-4 py-6" id="main-content">
      <slot />
    </main>

    <footer class="border-t border-gray-200 py-6 text-center text-xs text-gray-500 dark:border-gray-800 dark:text-gray-600" id="page-footer">
      Piano Book Index &mdash; Personal reference tool
    </footer>

    <PWABottomNav client:load currentPath={currentPath} />
    <PWAInstallPrompt client:load />

    <script is:inline>
      const applyOwnershipState = () => {
        const ownedIds = new Set();
        for (let i = 0; i < localStorage.length; i += 1) {
          const key = localStorage.key(i);
          if (!key || !key.startsWith('owned:')) continue;
          if (localStorage.getItem(key) === 'true') {
            ownedIds.add(key.replace('owned:', ''));
          }
        }

        document.querySelectorAll('[data-owned-card][data-book-id]').forEach((el) => {
          const bookId = el.getAttribute('data-book-id');
          const isOwned = Boolean(bookId && ownedIds.has(bookId));
          el.classList.toggle('owned-book', isOwned);
          el.setAttribute('data-owned', isOwned ? 'true' : 'false');
        });

        document.querySelectorAll('[data-owned-indicator][data-book-id]').forEach((el) => {
          const bookId = el.getAttribute('data-book-id');
          const isOwned = Boolean(bookId && ownedIds.has(bookId));
          el.classList.toggle('hidden', !isOwned);
        });
      };

      applyOwnershipState();
      window.addEventListener('storage', applyOwnershipState);
      window.addEventListener('owned-books-changed', applyOwnershipState);
      document.addEventListener('astro:after-swap', applyOwnershipState);

      const applyFavoritesState = () => {
        const favIds = new Set();
        for (let i = 0; i < localStorage.length; i += 1) {
          const key = localStorage.key(i);
          if (!key || !key.startsWith('fav:')) continue;
          favIds.add(key.replace('fav:', ''));
        }

        document.querySelectorAll('[data-fav-toggle][data-song-id]').forEach((el) => {
          const songId = el.getAttribute('data-song-id');
          const isFav = Boolean(songId && favIds.has(songId));
          el.textContent = isFav ? '♥' : '♡';
          if (isFav) {
            el.classList.add('text-pink-500', 'dark:text-pink-400');
            el.classList.remove('text-gray-300', 'dark:text-gray-600');
          } else {
            el.classList.remove('text-pink-500', 'dark:text-pink-400');
            el.classList.add('text-gray-300', 'dark:text-gray-600');
          }
        });
      };

      const handleFavToggleClick = (e) => {
        const btn = e.target.closest('[data-fav-toggle][data-song-id]');
        if (!btn) return;
        e.preventDefault();
        const songId = btn.getAttribute('data-song-id');
        if (!songId) return;
        const key = 'fav:' + songId;
        const existing = localStorage.getItem(key);
        if (existing) {
          localStorage.removeItem(key);
          window.dispatchEvent(new CustomEvent('favorites-changed', { detail: { songId, status: null, removed: true } }));
        } else {
          localStorage.setItem(key, JSON.stringify({ status: 'want-to-learn', favoritedAt: Date.now() }));
          window.dispatchEvent(new CustomEvent('favorites-changed', { detail: { songId, status: 'want-to-learn', removed: false } }));
        }
        applyFavoritesState();
      };

      document.addEventListener('click', handleFavToggleClick);
      applyFavoritesState();
      window.addEventListener('storage', applyFavoritesState);
      window.addEventListener('favorites-changed', applyFavoritesState);
      document.addEventListener('astro:after-swap', applyFavoritesState);

      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      // In standalone PWA mode, add bottom padding for the tab bar and hide footer
      (function() {
        var isStandalone = navigator.standalone === true ||
          window.matchMedia('(display-mode: standalone)').matches;
        if (isStandalone && window.innerWidth < 640) {
          var main = document.getElementById('main-content');
          var footer = document.getElementById('page-footer');
          if (main) main.style.paddingBottom = '5rem';
          if (footer) footer.style.display = 'none';
        }
      })();
    </script>
  </body>
</html>
