---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Browse and search piano songs across Faber and Alfred method book series' } = Astro.props;
const currentPath = Astro.url.pathname;

import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';
---

<!doctype html>
<html lang="en" class="dark:bg-gray-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#7e22ce" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <title>{title} | Piano Book Index</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        var d = t === 'dark' || (!t || t === 'system') && window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', d);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-950 dark:text-gray-100">
    <header class="sticky top-0 z-50 border-b border-gray-200 bg-white/80 backdrop-blur dark:border-gray-800 dark:bg-gray-950/80">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-piano-700 dark:text-piano-400">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="3" width="22" height="18" rx="2" fill="currentColor" opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
            <rect x="3" y="5" width="3.5" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="7" y="5" width="3.5" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="11" y="5" width="3.5" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="15" y="5" width="3.5" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="19" y="5" width="2.5" height="11" rx="0.5" fill="white" stroke="currentColor" stroke-width="0.75"/>
            <rect x="5.5" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
            <rect x="9.5" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
            <rect x="15.5" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
            <rect x="19.5" y="5" width="2" height="7" rx="0.5" fill="currentColor"/>
          </svg>
          <span>Piano Book Index</span>
        </a>
        <div class="flex items-center gap-1">
          <ul class="hidden items-center gap-1 text-sm sm:flex">
            <li>
              <a
                href="/search"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/search' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Search
              </a>
            </li>
            <li>
              <a
                href="/books"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath.startsWith('/books') && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Books
              </a>
            </li>
            <li>
              <a
                href="/favorites"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/favorites' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Favorites
              </a>
            </li>
            <li>
              <a
                href="/difficulty"
                class:list={[
                  'rounded-md px-3 py-2 transition-colors hover:bg-gray-100 dark:hover:bg-gray-800',
                  currentPath === '/difficulty' && 'bg-piano-100 font-medium text-piano-700 dark:bg-piano-900/30 dark:text-piano-400',
                ]}
              >
                Difficulty
              </a>
            </li>
          </ul>
          <div class="hidden sm:block">
            <ThemeToggle client:load />
          </div>
          <!-- Mobile menu button -->
          <div class="relative sm:hidden" id="mobile-menu-container">
            <button
              id="mobile-menu-btn"
              class="rounded-md p-2 text-gray-500 transition-colors hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800"
              aria-label="Menu"
            >
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
            </button>
            <div
              id="mobile-menu-dropdown"
              class="absolute right-0 top-full z-50 mt-1 hidden w-48 rounded-lg border border-gray-200 bg-white py-1 shadow-lg dark:border-gray-700 dark:bg-gray-900"
            >
              <a
                href="/difficulty"
                class:list={[
                  'block px-4 py-2.5 text-sm transition-colors hover:bg-gray-50 dark:hover:bg-gray-800',
                  currentPath === '/difficulty'
                    ? 'font-medium text-piano-700 dark:text-piano-400'
                    : 'text-gray-700 dark:text-gray-300',
                ]}
              >
                Difficulty Reference
              </a>
              <div class="border-t border-gray-100 dark:border-gray-800">
                <div class="px-4 py-2.5">
                  <ThemeToggle client:load />
                </div>
              </div>
            </div>
          </div>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-6 pb-20 sm:pb-6">
      <slot />
    </main>

    <footer class="mb-16 border-t border-gray-200 py-6 text-center text-xs text-gray-500 sm:mb-0 dark:border-gray-800 dark:text-gray-600">
      Piano Book Index &mdash; Personal reference tool
    </footer>

    <!-- Mobile bottom tab bar -->
    <nav class="fixed inset-x-0 bottom-0 z-50 border-t border-gray-200 bg-white/95 backdrop-blur safe-bottom sm:hidden dark:border-gray-800 dark:bg-gray-950/95">
      <div class="mx-auto grid max-w-lg grid-cols-4">
        <a
          href="/"
          class:list={[
            'flex flex-col items-center gap-0.5 py-2 text-[11px] transition-colors',
            currentPath === '/'
              ? 'text-piano-600 dark:text-piano-400'
              : 'text-gray-500 dark:text-gray-400',
          ]}
        >
          <svg class="h-5 w-5" fill={currentPath === '/' ? 'currentColor' : 'none'} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955a1.126 1.126 0 0 1 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
          Home
        </a>
        <a
          href="/search"
          class:list={[
            'flex flex-col items-center gap-0.5 py-2 text-[11px] transition-colors',
            currentPath === '/search'
              ? 'text-piano-600 dark:text-piano-400'
              : 'text-gray-500 dark:text-gray-400',
          ]}
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          Search
        </a>
        <a
          href="/books"
          class:list={[
            'flex flex-col items-center gap-0.5 py-2 text-[11px] transition-colors',
            currentPath.startsWith('/books')
              ? 'text-piano-600 dark:text-piano-400'
              : 'text-gray-500 dark:text-gray-400',
          ]}
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          Books
        </a>
        <a
          href="/favorites"
          class:list={[
            'flex flex-col items-center gap-0.5 py-2 text-[11px] transition-colors',
            currentPath === '/favorites'
              ? 'text-piano-600 dark:text-piano-400'
              : 'text-gray-500 dark:text-gray-400',
          ]}
        >
          <svg class="h-5 w-5" fill={currentPath === '/favorites' ? 'currentColor' : 'none'} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
          Favorites
        </a>
      </div>
    </nav>

    <script is:inline>
      const applyOwnershipState = () => {
        const ownedIds = new Set();
        for (let i = 0; i < localStorage.length; i += 1) {
          const key = localStorage.key(i);
          if (!key || !key.startsWith('owned:')) continue;
          if (localStorage.getItem(key) === 'true') {
            ownedIds.add(key.replace('owned:', ''));
          }
        }

        document.querySelectorAll('[data-owned-card][data-book-id]').forEach((el) => {
          const bookId = el.getAttribute('data-book-id');
          const isOwned = Boolean(bookId && ownedIds.has(bookId));
          el.classList.toggle('owned-book', isOwned);
          el.setAttribute('data-owned', isOwned ? 'true' : 'false');
        });

        document.querySelectorAll('[data-owned-indicator][data-book-id]').forEach((el) => {
          const bookId = el.getAttribute('data-book-id');
          const isOwned = Boolean(bookId && ownedIds.has(bookId));
          el.classList.toggle('hidden', !isOwned);
        });
      };

      applyOwnershipState();
      window.addEventListener('storage', applyOwnershipState);
      window.addEventListener('owned-books-changed', applyOwnershipState);
      document.addEventListener('astro:after-swap', applyOwnershipState);

      const applyFavoritesState = () => {
        const favIds = new Set();
        for (let i = 0; i < localStorage.length; i += 1) {
          const key = localStorage.key(i);
          if (!key || !key.startsWith('fav:')) continue;
          favIds.add(key.replace('fav:', ''));
        }

        document.querySelectorAll('[data-fav-toggle][data-song-id]').forEach((el) => {
          const songId = el.getAttribute('data-song-id');
          const isFav = Boolean(songId && favIds.has(songId));
          el.textContent = isFav ? '♥' : '♡';
          if (isFav) {
            el.classList.add('text-pink-500', 'dark:text-pink-400');
            el.classList.remove('text-gray-300', 'dark:text-gray-600');
          } else {
            el.classList.remove('text-pink-500', 'dark:text-pink-400');
            el.classList.add('text-gray-300', 'dark:text-gray-600');
          }
        });
      };

      const handleFavToggleClick = (e) => {
        const btn = e.target.closest('[data-fav-toggle][data-song-id]');
        if (!btn) return;
        e.preventDefault();
        const songId = btn.getAttribute('data-song-id');
        if (!songId) return;
        const key = 'fav:' + songId;
        const existing = localStorage.getItem(key);
        if (existing) {
          localStorage.removeItem(key);
          window.dispatchEvent(new CustomEvent('favorites-changed', { detail: { songId, status: null, removed: true } }));
        } else {
          localStorage.setItem(key, JSON.stringify({ status: 'want-to-learn', favoritedAt: Date.now() }));
          window.dispatchEvent(new CustomEvent('favorites-changed', { detail: { songId, status: 'want-to-learn', removed: false } }));
        }
        applyFavoritesState();
      };

      document.addEventListener('click', handleFavToggleClick);
      applyFavoritesState();
      window.addEventListener('storage', applyFavoritesState);
      window.addEventListener('favorites-changed', applyFavoritesState);
      document.addEventListener('astro:after-swap', applyFavoritesState);

      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      // Mobile menu dropdown toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const menuDropdown = document.getElementById('mobile-menu-dropdown');
      if (menuBtn && menuDropdown) {
        menuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          menuDropdown.classList.toggle('hidden');
        });
        document.addEventListener('click', () => {
          menuDropdown.classList.add('hidden');
        });
      }
    </script>
  </body>
</html>
